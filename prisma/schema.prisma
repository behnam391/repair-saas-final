// ─────────────────────────────────────────────────────────────
// Repair Shop SaaS — Database Schema
// Multi-tenant model: every business table carries shopId so one
// Postgres database safely serves many shops (row-level isolation
// enforced in lib/tenant.ts on every query, not just here).
// ─────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Tenant ──────────────────────────────────────────────────

model Shop {
  id            String   @id @default(cuid())
  name          String
  phone         String?
  address       String?
  // "REPAIR" (repair shop, default) | "DEALER" (phone buy/sell dealer) | "BOTH"
  type          String   @default("REPAIR")
  // subscription plan: "free" | "pro" | "business"
  plan          String   @default("free")
  planExpiresAt DateTime?
  active        Boolean  @default(true) // super admin can suspend a shop
  // monthly device-intake quota enforced for the "free" plan
  monthlyQuota  Int      @default(10)
  smsSenderName String? // shown as the sender name in outgoing SMS
  bankCardNumber    String? // shown on invoice/SMS if the shop opts in
  bankAccountNumber String?
  createdAt     DateTime @default(now())

  users         User[]
  customers     Customer[]
  tickets       Ticket[]
  inventory     InventoryItem[]
  invoices      Invoice[]
  marketListings MarketListing[]
  marketReplies  MarketReply[]
  subscriptions  Subscription[]
  deviceFlags        DeviceFlag[]
  deviceTransactions DeviceTransaction[]
  favoriteBrands     FavoriteBrand[]
  customDeviceModels CustomDeviceModel[]
  issueTemplates     IssueTemplate[]
  supportTickets     SupportTicket[]
  returns            ReturnRecord[]
  partRequests       PartRequest[]
  referencePrices    ReferencePrice[]
}

// You — the SaaS owner — sign in separately from every shop's staff.
// Deliberately not tied to a Shop, so it isn't caught by any tenant-scoped
// query, and can't be created through the public signup flow.
model PlatformAdmin {
  id           String   @id @default(cuid())
  name         String
  phone        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

enum SubscriptionStatus {
  PENDING
  PAID
  FAILED
}

// One row per checkout attempt against Zarinpal. Successful payment
// extends Shop.planExpiresAt by 30 days and sets Shop.plan.
model Subscription {
  id        String             @id @default(cuid())
  shopId    String
  shop      Shop               @relation(fields: [shopId], references: [id])
  plan      String             // "pro" | "business"
  amount    Int                // toman
  authority String?            // Zarinpal Authority token for this attempt
  refId     String?            // Zarinpal RefID once verified/paid
  status    SubscriptionStatus @default(PENDING)
  createdAt DateTime           @default(now())

  @@index([shopId])
}

// ── Users (shop staff) ──────────────────────────────────────

enum Role {
  OWNER     // full access: billing, staff management, all reports
  FRONTDESK // intake, customer-facing, invoicing
  HARDWARE
  SOFTWARE
  BOARD     // board-level / motherboard & data-recovery specialists
}

model User {
  id           String   @id @default(cuid())
  shopId       String
  shop         Shop     @relation(fields: [shopId], references: [id])
  name         String
  phone        String   @unique
  passwordHash String
  role         Role
  active       Boolean  @default(true)
  avatarUrl    String?
  email        String?
  gmailId      String?
  telegramId   String?
  nationalId   String?
  birthDate    DateTime?
  notifyEmail    Boolean @default(false)
  notifyTelegram Boolean @default(false)
  createdAt    DateTime @default(now())

  assignedTickets Ticket[]        @relation("AssignedTech")
  historyEntries  TicketHistory[]
  marketListings  MarketListing[]
  marketReplies   MarketReply[]
  deviceFlags        DeviceFlag[]
  deviceTransactions DeviceTransaction[]
  passwordResetTokens PasswordResetToken[]
  conversationsStarted Conversation[] @relation("ConversationStarter")
  messages             Message[]
  supportTickets       SupportTicket[]
  notifications        Notification[]
  partRequests          PartRequest[]

  @@index([shopId])
}

// ── Customers ────────────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  shopId    String
  shop      Shop     @relation(fields: [shopId], references: [id])
  name      String
  phone     String
  createdAt DateTime @default(now())

  tickets   Ticket[]

  @@index([shopId, phone])
}

// ── Repair workflow ─────────────────────────────────────────

// Which specialty lane a ticket currently sits in.
enum Lane {
  HARDWARE
  SOFTWARE
  BOARD
  READY     // repaired, awaiting pickup
}

enum TicketStatus {
  PENDING    // received by this lane, not started
  IN_PROGRESS
  AWAITING_APPROVAL // technician reported cost/parts, waiting on manager + customer sign-off
  REFERRED   // handed off to another lane
  READY
  DELIVERED
  CANCELLED
}

// How the customer acknowledged handing over the device at intake.
enum ReceiptAck {
  SHOP_PRINTED_SIGNED // shop already has its own pre-printed paper slip, customer signed that
  SITE_PRINTED_SIGNED // a receipt was printed from this system and the customer signed it
  NO_SIGNATURE         // device accepted with no signature/slip required
}

model Ticket {
  id            String       @id @default(cuid())
  shopId        String
  shop          Shop         @relation(fields: [shopId], references: [id])
  no            Int          // human-friendly sequential ticket number, scoped per shop
  customerId    String
  customer      Customer     @relation(fields: [customerId], references: [id])

  deviceModel   String
  imei          String?
  issueInitial  String       // the problem as described at intake
  devicePasscode String?     // customer's screen lock/passcode, only if they opted to give it (for post-repair testing)
  customerDamageNotes String? // pre-existing damage/prior repairs the customer discloses at intake
  receiptAck    ReceiptAck?  // how intake was acknowledged: shop's own printed slip, site-generated printed slip, or none

  lane          Lane
  status        TicketStatus @default(PENDING)
  assignedToId  String?
  assignedTo    User?        @relation("AssignedTech", fields: [assignedToId], references: [id])

  estimatedCost Int?         // toman
  finalCost     Int?
  technicianReportedCost Int? // cost the assigned technician proposes, awaiting manager approval
  technicianWage         Int? // manager-set wage paid to the technician for this repair
  technicianNote         String? // technician's note explaining the proposed cost/parts

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deliveredAt   DateTime?

  history       TicketHistory[]
  invoice       Invoice?
  partsUsed     TicketPart[]

  @@unique([shopId, no])
  @@index([shopId, lane, status])
}

// Every transition (intake, start, referral, completion) is logged here —
// this IS the "stamped repair tag" timeline shown in the UI.
model TicketHistory {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id])
  action    String   // e.g. "پذیرش دستگاه", "ارجاع به نرم‌افزار", "آماده تحویل"
  lane      Lane
  techId    String?
  tech      User?    @relation(fields: [techId], references: [id])
  note      String?
  createdAt DateTime @default(now())

  @@index([ticketId])
}

// ── Inventory ────────────────────────────────────────────────

model InventoryItem {
  id          String   @id @default(cuid())
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  name        String   // e.g. "LCD سامسونگ A54"
  sku         String?
  quantity    Int      @default(0)
  lowStockAt  Int      @default(2)
  costPrice   Int      // toman, what the shop paid
  sellPrice   Int      // toman, what the shop charges
  condition   String   @default("WORKING") // "WORKING" | "DEFECTIVE" — defective stock kept for parts/reference, not sold
  frequentlyUsed Boolean @default(false) // starred by the shop for quick pick in invoices

  usedIn      TicketPart[]

  @@index([shopId])
}

// Join table: which parts were consumed on which ticket (drives
// both inventory deduction and per-technician profit reporting).
model TicketPart {
  id          String        @id @default(cuid())
  ticketId    String
  ticket      Ticket        @relation(fields: [ticketId], references: [id])
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id])
  quantity    Int           @default(1)
  priceCharged Int          // toman, locked in at time of use
}

// ── Invoicing ────────────────────────────────────────────────

model Invoice {
  id         String   @id @default(cuid())
  shopId     String
  shop       Shop     @relation(fields: [shopId], references: [id])
  ticketId   String   @unique
  ticket     Ticket   @relation(fields: [ticketId], references: [id])
  laborCost  Int      // toman
  partsCost  Int      // toman, sum of TicketPart.priceCharged
  technicianWage Int  @default(0) // paid out to the assigned technician
  total      Int
  paid       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([shopId])
}

// One-time SMS code for the forgot-password flow. Short-lived (10 min)
// and single-use; never store the plain reset link, only this code.
model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  code      String   // 5-digit numeric OTP sent via SMS
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// ── Nationwide marketplace ───────────────────────────────────
// Unlike every other model above, these are NOT shop-isolated on read —
// any signed-in technician from any shop can see listings from any other
// shop (that's the whole point: connecting technicians nationwide). Writes
// are still tagged with shopId/authorId so we know who posted what and can
// let them manage/close their own posts.

enum ListingCategory {
  BOARD       // شماتیک / نقشه برد
  FLASH_FILE  // فایل فلش رسمی/تست‌شده
  PART        // قطعه فیزیکی (IC، LCD، باتری و...)
  EXPERTISE   // مشاوره یا کمک تخصصی
  OTHER
}

enum ListingStatus {
  OPEN
  RESOLVED
}

enum ListingType {
  REQUEST // "دنبال این می‌گردم"
  OFFER   // "این را دارم / برای فروش دارم"
}

model MarketListing {
  id           String          @id @default(cuid())
  shopId       String
  shop         Shop            @relation(fields: [shopId], references: [id])
  authorId     String
  author       User            @relation(fields: [authorId], references: [id])
  listingType  ListingType     @default(REQUEST)

  category     ListingCategory
  title        String
  description  String
  deviceModel  String?         // e.g. "Samsung A54" — makes search precise

  province     String
  city         String

  status       ListingStatus   @default(OPEN)
  showContact  Boolean         @default(true) // author can hide phone/address on this post
  createdAt    DateTime        @default(now())

  replies       MarketReply[]
  conversations Conversation[]

  @@index([province, city])
  @@index([category, status])
}

// Direct 1-to-1 chat thread on a listing, like Divar's "چت" button —
// separate from the public MarketReply comments above. One conversation
// per (listing, interested user) pair; the listing author is always the
// other participant.
model Conversation {
  id            String        @id @default(cuid())
  listingId     String
  listing       MarketListing @relation(fields: [listingId], references: [id])
  starterId     String        // the interested user who opened the chat
  starter       User          @relation("ConversationStarter", fields: [starterId], references: [id])
  createdAt     DateTime      @default(now())

  messages      Message[]

  @@unique([listingId, starterId])
  @@index([listingId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id])
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId])
}

model MarketReply {
  id          String        @id @default(cuid())
  listingId   String
  listing     MarketListing @relation(fields: [listingId], references: [id])
  shopId      String
  shop        Shop          @relation(fields: [shopId], references: [id])
  authorId    String
  author      User          @relation(fields: [authorId], references: [id])
  message     String
  createdAt   DateTime      @default(now())

  @@index([listingId])
}

// ── Nationwide device history ("medical record" by IMEI) ────
// Like the marketplace above, these are intentionally NOT shop-isolated
// on read: the whole point is that any shop, anywhere in Iran, searching
// an IMEI sees the device's full repair + ownership history — even
// history recorded by a different shop. Ticket.imei already gives free
// repair-history lookup (see /api/devices/[imei]); these two models add
// the crowd-sourced flag and the resale/ownership chain on top of that.

enum FlagType {
  STOLEN
  INSTALLMENT_DEBT // قسط پرداخت‌نشده / در گرو بانک یا فروشگاه
  OTHER
}

// Crowd-sourced warning, NOT an official/legal registry check — this is
// reported by fellow technicians/dealers, not verified against police or
// carrier records. The UI must always display it with that caveat.
model DeviceFlag {
  id          String   @id @default(cuid())
  imei        String
  flagType    FlagType
  note        String
  shopId      String
  shop        Shop     @relation(fields: [shopId], references: [id])
  reporterId  String
  reporter    User     @relation(fields: [reporterId], references: [id])
  createdAt   DateTime @default(now())

  @@index([imei])
}

// One row per sale logged by a dealer — builds the ownership chain
// ("previously owned by X, sold to Y, by which dealer, on what date").
model DeviceTransaction {
  id          String   @id @default(cuid())
  imei        String
  deviceModel String
  sellerName  String
  sellerPhone String?
  buyerName   String
  buyerPhone  String?
  price       Int?     // toman, optional
  note        String?
  shopId      String   // the dealer who logged this transaction
  shop        Shop     @relation(fields: [shopId], references: [id])
  loggedById  String
  loggedBy    User     @relation(fields: [loggedById], references: [id])
  createdAt   DateTime @default(now())

  @@index([imei])
}


// ── Device catalog customization ────────────────────────────
// The brand/model list itself is a static catalog in lib/device-catalog.ts
// (shared by all shops, like a phone book). These two tables let each shop
// personalize it: star brands they see most for quick access, and add
// models/brands that aren't in the static list without editing code.

model FavoriteBrand {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])
  brand  String

  @@unique([shopId, brand])
}

model CustomDeviceModel {
  id      String @id @default(cuid())
  shopId  String
  shop    Shop   @relation(fields: [shopId], references: [id])
  brand   String
  model   String
  createdAt DateTime @default(now())

  @@index([shopId])
}

// ── Editable issue templates ─────────────────────────────────
// Quick-pick chips shown on the intake form per specialty lane, seeded
// with sensible defaults but fully editable per shop (add/rename/remove).
model IssueTemplate {
  id     String @id @default(cuid())
  shopId String
  shop   Shop   @relation(fields: [shopId], references: [id])
  lane   Lane   // which specialty tab this chip shows under
  label  String

  @@index([shopId, lane])
}

// ── Platform support ─────────────────────────────────────────
enum SupportStatus {
  OPEN
  CLOSED
}

model SupportTicket {
  id        String        @id @default(cuid())
  shopId    String
  shop      Shop          @relation(fields: [shopId], references: [id])
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  subject   String
  message   String
  status    SupportStatus @default(OPEN)
  createdAt DateTime      @default(now())

  replies   SupportReply[]
}

model SupportReply {
  id              String        @id @default(cuid())
  supportTicketId String
  supportTicket   SupportTicket @relation(fields: [supportTicketId], references: [id])
  fromPlatform    Boolean       // true = platform admin replied, false = shop replied
  message         String
  createdAt       DateTime      @default(now())

  @@index([supportTicketId])
}

// ── Returns / refunds ────────────────────────────────────────
model ReturnRecord {
  id            String   @id @default(cuid())
  shopId        String
  shop          Shop     @relation(fields: [shopId], references: [id])
  ticketId      String?
  deviceModel   String
  customerName  String
  customerPhone String?
  reason        String
  refundAmount  Int?
  createdAt     DateTime @default(now())

  @@index([shopId])
}

// ── Platform-wide settings (super admin editable) ────────────
// Singleton row (id always "singleton") so API keys can be rotated from
// the super-admin dashboard instead of redeploying with new env vars.
// lib/sms.ts and lib/zarinpal.ts read this first and fall back to env
// vars if no row exists yet.
model PlatformSettings {
  id                  String  @id @default("singleton")
  kavenegarApiKey     String?
  kavenegarSender     String?
  zarinpalMerchantId  String?
  updatedAt           DateTime @updatedAt
}

// ── In-app notifications ──────────────────────────────────────
// Personal notifications (e.g. "someone needs a part you have listed",
// "manager approved your price") plus platform-wide broadcasts from the
// super admin (one row per recipient, isBroadcast just marks the origin).
model Notification {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  title       String
  message     String
  link        String?  // optional in-app path to open on click
  isBroadcast Boolean  @default(false)
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([userId, read])
}

// ── Ad space (super admin managed) ────────────────────────────
model AdBanner {
  id        String   @id @default(cuid())
  imageUrl  String
  linkUrl   String?
  active    Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
}

// ── Part purchase requests (technician → manager) ─────────────
// When a technician needs a part they don't have, they can either log
// it directly in inventory themselves, or raise a request the manager
// fulfills (purchases and adds to inventory).
enum PartRequestStatus {
  PENDING
  FULFILLED
  REJECTED
}

model PartRequest {
  id           String            @id @default(cuid())
  shopId       String
  shop         Shop              @relation(fields: [shopId], references: [id])
  requestedById String
  requestedBy   User             @relation(fields: [requestedById], references: [id])
  ticketId     String?
  itemName     String
  note         String?
  status       PartRequestStatus @default(PENDING)
  createdAt    DateTime          @default(now())

  @@index([shopId, status])
}

// ── Reference repair pricing guide ────────────────────────────
// NOT a live feed from Iran's mobile guild (اصناف موبایل ایران) — no
// public API exists for that. This is a manually-maintained reference
// table shops can fill in themselves (or copy from official guild
// bulletins) so technicians see a suggested fair price while working an
// issue, encouraging more consistent pricing nationwide.
model ReferencePrice {
  id          String @id @default(cuid())
  shopId      String
  shop        Shop   @relation(fields: [shopId], references: [id])
  deviceModel String
  issueLabel  String // matches an IssueTemplate label where possible
  suggestedPrice Int // toman
  source      String? // e.g. "بخشنامه اصناف تیر ۱۴۰۵" — free text citation
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}
